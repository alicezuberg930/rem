{
  "name": "rem",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alicezuberg930/yvonne.git"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "turbo": "2.6.3",
    "typescript": "5.9.2",
    "typescript-eslint": "8.57.2"
  },
  "bugs": {
    "url": "https://github.com/alicezuberg930/yvonne/issues"
  },
  "catalog": {
    "typescript": "5.9.2",
    "tsdown": "^0.17.2",
    "@types/node": "24.10.1",
    "eslint": "^10.1.0"
  },
  "catalogs": {
    "tailwind": {
      "@tailwindcss/vite": "4.2.2",
      "tailwindcss": "4.2.2"
    },
    "react": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://yvonne-one.vercel.app",
  "packageManager": "bun@1.3.4",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=rem-web-dashboard",
    "dev:web": "turbo run dev --filter=rem-web-dashboard",
    "dev:server": "cd rem-server && ./mvnw spring-boot:run",
    "server:install": "cd rem-server && ./mvnw clean install -DskipTests",
    "server:compile": "cd rem-server && ./mvnw clean compile",
    "server:build": "cd rem-server && ./mvnw clean build -DskipTests",
    "deps:bump": "bunx npm-check-updates --deep -u && bun install",
    "lint": "turbo run lint",
    "format:check": "prettier --check .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "rem-server/*"
  ]
}